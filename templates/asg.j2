# Auto Scaling Group
resource "aws_launch_template" "{{id}}_lt" {
  name_prefix   = "{{id}}-"
  image_id      = "ami-0c55b159cbfafe1f0" # Amazon Linux 2 (update for your region)
  instance_type = "t2.micro"

  tags = {
    Name    = "{{id}}-template"
    Purpose = "{{purpose}}"
  }
}

resource "aws_autoscaling_group" "{{id}}" {
  name                = "{{id}}"
  desired_capacity    = 2
  max_size            = 4
  min_size            = 1
  # Note: vpc_zone_identifier must be configured based on your VPC subnets
  # vpc_zone_identifier = [aws_subnet.private_1.id, aws_subnet.private_2.id]

  launch_template {
    id      = aws_launch_template.{{id}}_lt.id
    version = "$Latest"
  }

  tag {
    key                 = "Name"
    value               = "{{id}}"
    propagate_at_launch = true
  }
}
