# API Gateway
resource "aws_apigatewayv2_api" "{{id}}" {
  name          = "{{id}}"
  protocol_type = "HTTP"
  description   = "{{purpose}}"
  
  tags = {
    Name    = "{{id}}"
    Purpose = "{{purpose}}"
  }
}

resource "aws_apigatewayv2_stage" "{{id}}_default" {
  api_id      = aws_apigatewayv2_api.{{id}}.id
  name        = "$default"
  auto_deploy = true
}
